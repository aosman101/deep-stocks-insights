# Core app
DEBUG=true
ENVIRONMENT=development
DATABASE_URL=sqlite:////tmp/deep_stock_insights.db

# Security
# Generate a long random value before using outside local development.
SECRET_KEY=replace-with-a-random-secret

# Optional admin bootstrap
ADMIN_EMAIL=admin@deepstockinsights.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# Optional API keys (platform works without these)
GOLD_API_KEY=         # goldapi.io — live gold spot price
FRED_API_KEY=         # register free at https://fred.stlouisfed.org/docs/api/api_key.html
FINNHUB_API_KEY=      # finnhub.io — company news, profiles, earnings, sentiment
TWELVE_DATA_API_KEY=  # twelvedata.com — time series, technical indicators, forex
